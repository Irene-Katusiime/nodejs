<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NyondoStock - Store Manager</title>
    <link rel="stylesheet" href="/css/managerdashboard.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="manager-container">
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>NyondoStock</h2>
                <p>Store Manager</p>
            </div>
            <ul class="nav-links">
                <li class="active"><a href="#">Inventory Overview</a></li>
                <li><a href="#">Register New Stock</a></li>
                <li><a href="#">Supplier Credit Ledger</a></li>
                <li><a href="#">Pricing & Margins</a></li>
                <li><a href="#">Damage Reports</a></li>
            </ul>
            <div class="sidebar-footer">
                <a href="/logout" class="logout">Logout</a>
            </div>
        </nav>

        <main class="main-content">
            <header class="top-bar">
                <div class="welcome">
                    <h1>Inventory Control</h1>
                    <p>Monday, 27th April 2026</p>
                </div>
                <div class="quick-actions">
                    <button class="btn-primary">+ Add New Item</button>
                </div>
            </header>

            <section class="summary-grid">
                <div class="summary-card">
                    <h3>Total Items</h3>
                    <p class="value">1,240</p>
                </div>
                <div class="summary-card warning">
                    <h3>Low Stock Alerts</h3>
                    <p class="value">8</p>
                </div>
                <div class="summary-card debt">
                    <h3>Supplier Credit</h3>
                    <p class="value">UGX 4.2M</p>
                </div>
            </section>

            <section class="inventory-table">
                <div class="table-header">
                    <h3>Current Stock Levels</h3>
                    <input type="text" placeholder="Filter by category..." class="table-search">
                </div>
                <table>
                    <thead>
                        <tr>
                            <th>Item Name</th>
                            <th>Cost Price</th>
                            <th>Selling Price</th>
                            <th>In Stock</th>
                            <th>Reorder Point</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Cement (Tororo)</td>
                            <td>29,000</td>
                            <td>33,000</td>
                            <td>150</td>
                            <td>20</td>
                            <td><span class="badge success">Healthy</span></td>
                        </tr>
                        <tr>
                            <td>Iron Sheets (Blue)</td>
                            <td>42,000</td>
                            <td>48,000</td>
                            <td>12</td>
                            <td>15</td>
                            <td><span class="badge danger">Restock</span></td>
                        </tr>
                    </tbody>
                </table>
            </section>
        </main>
    </div>
</body>
</html>