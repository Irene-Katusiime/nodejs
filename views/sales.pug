doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Nyondo sales
  link(rel='stylesheet' href='/css/sales.css')
// Sidebar
.sidebar
  h2 Nyondo Stock
  a(href='#') Dashboard
  a(href='/add-stock') Stock
  a.active(href='/sales') Sales
  a(href='#') Suppliers
  a(href='#') Deposits
// Main content
.main
  h1 Sales Management
  // sales form
  .form-container
    h2 Record Sale
    form(action='/sales' method='post')
      //- .form-group
      //-   label Date
      //-   input(type='date' name='date')
      .form-group
        label Item Name
          select(name='itemId')
            option(value='' disabled selected) Select item
            each item in items 
              option(value=item._id) #{item.itemName} (stock:#{item.quantity} | price:#{item.sellingprice}UGX)
      .form-group
        label Quantity
        input(type='number' name='quantity' placeholder='Enter quantity' required='')
      .form-group
        label Unit Price (UGX)
        input(type='number' name='unitprice' placeholder='Enter price' required='')
      .form-group
        label Customer Name
        input(type='text' name='customername' placeholder='Enter customer name' required='')
      .form-group
        label Customer Contact
        input(type='number' name='customercontact' placeholder='Enter customer contact' required='')
      button(type='submit') Add Sale
  // Sales Table
  .table-container
    h2 Sales Records
    table
      tr
        th Item
        th Quantity
        th Price (UGX)
        th Total
      tbody
        tr
          td Cement
          td 10
          td 15000
          td 150000
        tr
          td Iron Sheets
          td 5
          td 40000
          td 200000
